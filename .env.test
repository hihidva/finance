# Test-mode env — loaded on top of .env when APP_ENV=test (i.e. `./run.sh start_test`).
#
# pydantic-settings reads .env first, then THIS file overrides. Per e2e-test-setup
# skill: this file is a COMPLETE copy of .env shape, not a sparse delta — that way
# missing/blank keys here can't silently fall back to dev credentials.
#
# Safe to commit: contains no live secrets.

# ---------------------------------------------------------------------------
# Database — SQLite test sandbox (no MySQL needed for UI dev / Playwright).
# Limitation: batch jobs that use `INSERT ... ON DUPLICATE KEY UPDATE`
# (sync-prices, eval-outcomes, bulk_upsert_*) WILL FAIL on SQLite.
# Test mode is intended for web-layer + watchlist CRUD only.
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./.cache/finance_test.db

# Blank legacy MYSQL_* so if any code path bypasses DATABASE_URL it fails
# loudly instead of silently hitting the dev MySQL database.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ---------------------------------------------------------------------------
# External side-effects DISABLED — tests must never spam real chats.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Claude Code CLI — health endpoint will probe `claude --version`.
# If the CLI isn't installed on the test runner, the LLM card on the dashboard
# shows FAILED; that's fine for UI tests since they don't exercise the arbiter.
# ---------------------------------------------------------------------------
CLAUDE_BINARY=claude
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# RAG — separate Chroma dir so we don't pollute the dev vector store.
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CHROMA_DIR=./.cache/chroma_test

# ---------------------------------------------------------------------------
# Verbose logging for tests
# ---------------------------------------------------------------------------
LOG_LEVEL=DEBUG
